#!/sbin/sh
# ==========================================
# UBLESTRAMK - Magisk Module Installer
# Standard Magisk update-binary
# ==========================================

OUTFD=$2
ZIPFILE=$3

mount /data 2>/dev/null

# Use ash for better compatibility
[ -f /sbin/ash ] && SHELL=/sbin/ash || SHELL=/sbin/sh

ui_print() {
    echo -n -e "ui_print $1\n" > /proc/self/fd/$OUTFD
    echo -e "$1" > /proc/self/fd/$OUTFD
}

require_new_abmagic() {
    ui_print "! Cannot install on current architecture"
    exit 1
}

# Print module info
ui_print "============================================"
ui_print "  UBLESTRAMK Installer"
ui_print "  Universal Boot-Lock Evasion Module"
ui_print "============================================"

# Unzip module files to /tmp
UNZIPDIR="/tmp/ublestramk_install"
rm -rf "$UNZIPDIR"
mkdir -p "$UNZIPDIR"
unzip -o "$ZIPFILE" -d "$UNZIPDIR" 2>/dev/null

if [ ! -f "$UNZIPDIR/module.prop" ]; then
    ui_print "! Invalid module package"
    exit 1
fi

# Read module info
MODID=$(grep "^id=" "$UNZIPDIR/module.prop" 2>/dev/null | cut -d= -f2)
MODNAME=$(grep "^name=" "$UNZIPDIR/module.prop" 2>/dev/null | cut -d= -f2)
MODVER=$(grep "^version=" "$UNZIPDIR/module.prop" 2>/dev/null | cut -d= -f2)

ui_print "- Module: $MODNAME"
ui_print "- Version: $MODVER"
ui_print "- Installing..."

# Remove old installation
rm -rf /data/adb/modules/$MODID 2>/dev/null

# Install new module
mkdir -p /data/adb/modules/$MODID
cp -r "$UNZIPDIR"/* /data/adb/modules/$MODID/

# Set permissions
chmod 755 /data/adb/modules/$MODID/*.sh 2>/dev/null
chmod 755 /data/adb/modules/$MODID/META-INF 2>/dev/null
chmod 755 /data/adb/modules/$MODID/META-INF/* 2>/dev/null
chmod 755 /data/adb/modules/$MODID/META-INF/*/* 2>/dev/null
chmod 644 /data/adb/modules/$MODID/*.prop 2>/dev/null
chmod 644 /data/adb/modules/$MODID/system.prop 2>/dev/null

# Clean up
rm -rf "$UNZIPDIR"

ui_print "- Module installed to /data/adb/modules/$MODID"
ui_print "============================================"
ui_print "  Installation complete!"
ui_print "  Please reboot to activate"
ui_print "============================================"

exit 0
